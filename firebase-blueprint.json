{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "student"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Task": {
      "title": "Task",
      "description": "A global lesson or task in the LSAT study guide",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "order"]
    },
    "UserProgress": {
      "title": "User Progress",
      "description": "Tracks completion of a task for a specific user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "taskId": { "type": "string" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "taskId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Global study guide tasks"
    },
    "/users/{userId}/progress/{taskId}": {
      "schema": "UserProgress",
      "description": "User-specific task completion status"
    }
  }
}
