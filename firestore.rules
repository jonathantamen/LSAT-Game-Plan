rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - role: string (required, 'admin' or 'student')
    //
    // Collection: tasks
    // Fields:
    //   - title: string (required)
    //   - description: string
    //   - order: number (required)
    //
    // Collection: users/{userId}/progress
    // Fields:
    //   - userId: string (required)
    //   - taskId: string (required)
    //   - completedAt: timestamp
    //
    // Collection: resources
    // Fields:
    //   - title: string (required)
    //   - fileUrl: string (required)
    //   - fileName: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'student'];
    }

    function isValidTask(data) {
      return data.keys().hasAll(['title', 'order']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.order is number &&
             (!('description' in data) || (data.description is string && data.description.size() < 10000)) &&
             (!('category' in data) || (data.category is string && data.category.size() < 100)) &&
             (!('linkUrl' in data) || (data.linkUrl is string && data.linkUrl.size() < 1000)) &&
             (!('linkText' in data) || (data.linkText is string && data.linkText.size() < 100));
    }

    function isValidProgress(data, userId, taskId) {
      return data.keys().hasAll(['userId', 'taskId']) &&
             data.userId == userId &&
             data.taskId == taskId;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['title', 'fileUrl']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.fileUrl is string && data.fileUrl.size() > 0 &&
             (!('fileName' in data) || (data.fileName is string && data.fileName.size() < 255));
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) &&
                    request.resource.data.role == 'student';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.role == resource.data.role;

      match /progress/{taskId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create, update: if isOwner(userId) && isValidProgress(request.resource.data, userId, taskId);
        allow delete: if isOwner(userId);
      }
    }

    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin() && isValidTask(request.resource.data);
      allow delete: if isAdmin();
    }

    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidResource(request.resource.data);
    }
  }
}
